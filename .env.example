# MongoDB Configuration
# Replace 'shining_star' with your database name
MONGODB_URI=mongodb://localhost:27017/shining_star

# Server Configuration
PORT=8000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:3000
JSON_BODY_LIMIT=1mb
ENABLE_API_DOCS=true

# Cloudinary Configuration (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Aakash SMS Configuration
AAKASH_SMS_TOKEN=your_aakash_sms_token
# Note: Aakash SMS requires the deployed backend server IP to be whitelisted.
# SMS delivery will only work when requests originate from the deployed backend.

# Email Configuration (optional, used for SuperAdmin credential delivery)
# SMTP_* is preferred. EMAIL_* aliases are also supported for host/port/secure/user/pass/from.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="Shining Star English School <no-reply@example.com>"

# Frontend login URL used inside delivery messages
APP_LOGIN_URL=http://localhost:3000/login

# Optional: scheduler poll interval in milliseconds
NOTIFICATION_SCHEDULE_POLL_MS=60000

# Seeded account configuration
# Quote passwords if they start with special characters such as #.
SEED_SUPERADMIN_PHONE=9999999999
SEED_SUPERADMIN_EMAIL=nikeshscript@gmail.com
SEED_SUPERADMIN_PASSWORD="replace-with-a-secure-superadmin-password"
SEED_ADMIN_PHONE=9841234567
SEED_ADMIN_EMAIL=admin.shiningstar@gmail.com
SEED_ADMIN_PASSWORD=replace-with-a-secure-admin-password
